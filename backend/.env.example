# ============================================================
# WC2026 后端环境变量模板
# 复制为 .env 后填入真实值：copy .env.example .env
# ============================================================

# ---------- PostgreSQL ----------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres

# ---------- 后端服务 ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=10086
CORS_ORIGINS=http://localhost:10087

# ---------- MiniMax AI ----------
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_TEMPERATURE=0.7

# ---------- BSD 足球数据（主数据源）----------
# 注册：https://sports.bzzoiro.com/register/
BSD_API_KEY=your_bsd_api_key
BSD_BASE_URL=https://sports.bzzoiro.com
BSD_API_VERSION=v2
BSD_LEAGUE_ID=27
BSD_SEASON_ID=188
BSD_TIMEZONE=Asia/Shanghai
FOOTBALL_PROVIDER=bsd
LIVE_POLL_INTERVAL_LIVE=60
# 无 live 赛事时可拉长到 600，减轻 2C 机器 CPU/带宽尖峰
LIVE_POLL_INTERVAL_IDLE=600
ENABLE_BACKGROUND_INGEST=true
ALLOW_MANUAL_SYNC=false
ADMIN_SYNC_SECRET=

# ---------- 限流 / 反代（Nginx 后面必须设 TRUSTED_PROXY_COUNT=1）----------
TRUSTED_PROXY_COUNT=0
GLOBAL_RATE_LIMIT_PER_MINUTE=300
GLOBAL_RATE_LIMIT_WINDOW_SEC=60

# ---------- API-Football（已弃用，可选备用）----------
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2022

# ---------- RSS 新闻（中英分源）----------
# 英文源（国际资讯）- 兼容旧变量 NEWS_RSS_FEEDS
NEWS_RSS_FEEDS=https://feeds.bbci.co.uk/sport/football/rss.xml
NEWS_RSS_FEEDS_EN=
# 中文源（国内直连，逗号分隔）
# 推荐：虎扑足球 + 人民网/中新网体育（综合体育源入库时会过滤非足球）
NEWS_RSS_FEEDS_ZH=https://rsshub.rssforever.com/hupu/soccer,http://www.people.com.cn/rss/sports.xml,https://www.chinanews.com.cn/rss/sports.xml
# 列表只展示最近 N 天；入库跳过更旧条目；库内超过 retention 天自动清理
NEWS_MAX_AGE_DAYS=30
NEWS_INGEST_MAX_AGE_DAYS=14
NEWS_RETENTION_DAYS=90

# ---------- Redis（可选）----------
REDIS_URL=

# ---------- 数据目录（可选）----------
# DATA_DIR=

# ---------- AI Agent ----------
# 发布稳定性建议：AI_MAX_CONCURRENT_LLM=1、AGENT_PARALLEL_LLM=false、MINIMAX_MAX_RETRIES=5
# API 进程保持单 worker（run.py 默认），勿 uvicorn --workers 4；ingest 独立进程时 ENABLE_BACKGROUND_INGEST=false
AGENT_ENABLE_TOOL_LOOP=false
AGENT_PARALLEL_LLM=false
AGENT_CRITIC_MODES=pre_match,post_match
AGENT_PREDICT_TEMPERATURE=0.35
AGENT_CACHE_HOURS_PRE_MATCH=24
AGENT_CACHE_MINUTES_LIVE=3
AGENT_MAX_STEPS=8
AGENT_DEFAULT_MODE=pre_match
AI_DAILY_TOKEN_BUDGET=500000
AI_DAILY_FORCE_REFRESH_LIMIT=5
AI_DAILY_FREE_ANALYSES=2
AI_COIN_COST_PRE_MATCH=15
AI_COIN_COST_LIVE=10
AI_COIN_COST_FORCE_REFRESH=10
AI_MAX_CONCURRENT_LLM=1
MINIMAX_MAX_RETRIES=5
MINIMAX_RETRY_BASE_SECONDS=1.5
SEASON_PASS_DAILY_COINS=50
SEASON_PASS_EXTRA_AI_FREE=3
NICKNAME_CHANGE_COST=20
ORDER_PENDING_REUSE_MINUTES=30
PRODUCTION_MODE=false

# ---------- Auth / SMTP ----------
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=最后一舞 <noreply@example.com>
SMTP_USE_TLS=true
AUTH_CODE_EXPIRE_MINUTES=10
NEW_USER_COINS=100
AUTH_DEV_MODE=true

# ---------- Alipay (公钥证书模式 / DCAliPay) ----------
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=keys/alipay_app_private.pem
ALIPAY_APP_CERT_PATH=keys/appCertPublicKey.crt
ALIPAY_ALIPAY_CERT_PATH=keys/alipayCertPublicKey_RSA2.crt
ALIPAY_ROOT_CERT_PATH=keys/alipayRootCert.crt
ALIPAY_NOTIFY_URL=http://localhost:10086/api/pay/alipay/notify
ALIPAY_RETURN_URL=http://localhost:10087/shop/result
ALIPAY_SANDBOX=true
ALIPAY_MOCK=true

# ---------- Game ----------
PREDICT_CLOSE_MINUTES_BEFORE=30
DAILY_FREE_PREDICT=1
DAILY_SIGNIN_COINS=20
PREDICT_STAKE_MIN=10
PREDICT_STAKE_MAX=500
PREDICT_WIN_REDEEM_RATIO=0.5
# 猜中可用积分 = 累计积分 × 上述比例（仅猜中发放，猜错为 0）

# ---------- 积分兑换商城（运行时数据源：数据库 products 表）----------
# 日常改价/上下架/新增 — 管理 API（生产环境需 X-Admin-Secret = ADMIN_SYNC_SECRET）：
#   curl http://localhost:10086/api/shop/admin/redeem/products -H "X-Admin-Secret: 你的密钥"
#   curl -X PATCH http://localhost:10086/api/shop/admin/redeem/products/1 \
#     -H "X-Admin-Secret: 你的密钥" -H "Content-Type: application/json" \
#     -d '{"redeem_price": 280}'
#   curl -X POST http://localhost:10086/api/shop/admin/redeem/products/1/toggle \
#     -H "X-Admin-Secret: 你的密钥"
# 或直接 SQL（同样无需重启后端）：
#   UPDATE products SET redeem_price=280, updated_at=NOW() WHERE sku='redeem_frame_silver';
# grant_payload 字段说明：GET /api/shop/redeem/rules 的 grant_payload_schema
# stock_total：全服库存，0=不限量；不会重置 stock_sold
# 空库初始化：alembic upgrade head（迁移 025 seed）或一次性 sync-catalog / sync_redeem_products.py
# bootstrap 默认清单：backend/app/data/redeem_product_catalog.py（仅初始化用）

# ---------- 召友裂变 ----------
REFERRAL_MAX_COINS_EARNED_PER_SEASON=800
REFERRAL_REGISTER_INVITEE_COINS=30
REFERRAL_PROFILE_INVITER_COINS=80
REFERRAL_PROFILE_INVITEE_COINS=20
REFERRAL_ACTION_INVITER_COINS=120
REFERRAL_ACTION_INVITEE_COINS=30
REFERRAL_ACTIVE_7D_INVITER_COINS=100
REFERRAL_SAME_TEAM_INVITER_COINS=50
REFERRAL_SAME_TEAM_BATTALION=80
# 召友周榜奖励（REFERRAL_WEEKLY_RANK_REWARDS）
# 格式：名次:赛季积分:球迷币  或  起-止:积分:币  多条用英文逗号分隔
# 例：1:300:150,2:250:120,3:200:100,4-10:100:0  → 第1名300分+150币，第4～10名各100分
REFERRAL_WEEKLY_RANK_REWARDS=1:200:100,2:200:100,3:200:100,4-10:200:0
REFERRAL_IP_DAILY_LIMIT=3
