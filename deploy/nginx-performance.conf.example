# Nginx performance snippet for WC2026 (include inside server { } block)
#
# Usage:
#   include /opt/wc2026/deploy/nginx-performance.conf;
#
# Assumes:
#   - API upstream on 127.0.0.1:10086
#   - Static frontend root at /opt/wc2026/WorldCup/frontend/dist

# Gzip text/json (5 Mbps uplink benefits greatly from compression)
gzip on;
gzip_vary on;
gzip_min_length 256;
gzip_comp_level 5;
gzip_types
  text/plain
  text/css
  text/javascript
  application/javascript
  application/json
  application/xml
  image/svg+xml;

# Frontend hashed assets — long cache (Vite adds content hash in filename)
location ~* ^/assets/.+\.(js|css|woff2?|png|jpg|jpeg|webp|svg|ico)$ {
  root /opt/wc2026/WorldCup/frontend/dist;
  expires 30d;
  add_header Cache-Control "public, immutable";
  try_files $uri =404;
}

# Large optional 3D model — do NOT deploy; use LegendsPageBackdrop instead
# location = /stadium.glb { return 404; }

# Legend backdrop images — long cache (run optimize-legends.py before deploy)
location ~* ^/legends/.+\.webp$ {
  root /opt/wc2026/WorldCup/frontend/dist;
  expires 30d;
  add_header Cache-Control "public, immutable";
  try_files $uri =404;
}

# Brand favicon + WeChat share card image
location ~* ^/(favicon-32\.png|favicon-192\.png|apple-touch-icon\.png|share-og\.png|logo\.svg)$ {
  root /opt/wc2026/WorldCup/frontend/dist;
  expires 30d;
  add_header Cache-Control "public, immutable";
  try_files $uri =404;
}

# WeChat / crawler OG HTML for invite links (backend serves /share/invite)
location /share/ {
  proxy_pass http://127.0.0.1:10086;
  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
}

# API — no cache, proxy to uvicorn
location /api/ {
  proxy_pass http://127.0.0.1:10086;
  proxy_http_version 1.1;
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_read_timeout 120s;
}

location /ws/ {
  proxy_pass http://127.0.0.1:10086;
  proxy_http_version 1.1;
  proxy_set_header Upgrade $http_upgrade;
  proxy_set_header Connection "upgrade";
  proxy_set_header Host $host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_read_timeout 3600s;
}
